<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Orfograffiti.settings"
             Title="">
    <Grid>
        <Image 
            x:Name="fon"
            Aspect="AspectFill"
            Source="whitefon.jfif"
            Opacity="0.5"/>
        <ScrollView>
            <VerticalStackLayout>
                <Border x:Name="bor1" Margin="20" Stroke="Black">
                    <VerticalStackLayout>
                        <Label 
                            Text="Версия: 1.0.0"
                            FontSize="18"
                            FontAttributes="Bold"
                            Margin="10"/>
                        <Label 
                            x:Name="platform"
                            Text="Платформа:"
                            FontSize="18"
                            FontAttributes="Bold"
                            Margin="10"/>
                    </VerticalStackLayout>
                </Border>
                <Border x:Name="bor2" Margin="20" Stroke="Black">
                    <VerticalStackLayout>
                        <HorizontalStackLayout>
                            <CheckBox x:Name="vibroCheck" CheckedChanged="vibroCheck_CheckedChanged"/>
                            <Image 
                                Source="vibro.png" 
                                HeightRequest="25" />
                            <Label 
                                Text="Вибрация"
                                FontSize="18"
                                FontAttributes="Bold"
                                VerticalOptions="Center"
                                Margin="5,0,0,0"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>